{
  "name": "whatsapp-connect-openclaw",
  "version": "2.0.0",
  "description": "Sistema completo WhatsApp para OpenClaw: servidor robusto, bot de reglas inteligente, monitoreo automático y funciones especiales Eroika",
  "main": "server-robust.js",
  "scripts": {
    "start": "node server-robust.js",
    "start-all": "./start-all.sh",
    "rules": "node whatsapp-rules-eroika-especial-fixed.js",
    "tunnel": "node tunnel.js",
    "monitor": "./monitor-services.sh",
    "dev": "nodemon server-robust.js",
    "test": "echo \"No tests yet\" && exit 0",
    "postinstall": "echo '✅ Dependencias instaladas. Configuración en server-robust.js (líneas 15-16) y whatsapp-rules-final.json'"
  },
  "keywords": [
    "openclaw",
    "whatsapp",
    "whatsapp-web",
    "automation",
    "bot",
    "assistant"
  ],
  "author": "Donna 🌹 <donna@openclaw.ai>",
  "license": "MIT",
  "dependencies": {
    "whatsapp-web.js": "^1.23.0",
    "qrcode-terminal": "^0.12.0",
    "qrcode": "^1.5.3",
    "express": "^4.18.2",
    "localtunnel": "^2.0.2"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  },
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=8.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Jaimemprendedor2/OpenClaw.git"
  },
  "bugs": {
    "url": "https://github.com/Jaimemprendedor2/OpenClaw/issues"
  },
  "homepage": "https://github.com/Jaimemprendedor2/OpenClaw#readme",
  "openclaw": {
    "skill": true,
    "category": "channels",
    "compatibility": ">=2026.4.5",
    "requires": [
      "chromium",
      "telegram-bot"
    ]
  }
}